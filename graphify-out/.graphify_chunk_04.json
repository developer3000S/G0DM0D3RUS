      "rationale": "Collects post-response quality signals (user ratings + automated heuristics) and uses Exponential Moving Average (EMA) to adjust LLM parameters per context type over time, blending learned adjustments with base profiles up to a 50% cap."
    },
    {
      "id": "lib_autotune_engine",
      "label": "AutoTune Engine",
      "file_type": "code",
      "source_file": "src/lib/autotune.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Evolved from Elder Plinius's AutoTemp. Analyzes conversation context BEFORE generation to apply optimal generation parameters (temp, top_p, etc.) in a single call, avoiding expensive multi-generation scoring at 1/N the cost."
    },
    {
      "id": "lib_classifyllm_classifier",
      "label": "LLM Harm Classifier",
      "file_type": "code",
      "source_file": "src/lib/classify-llm.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Runs parallel to the main model call using a fast/cheap OpenRouter LLM to classify user queries for harm, intent, obfuscation, or multilingual tricks. Avoids blocking user UI, falling back to regex on timeout/failure."
    },
    {
      "id": "lib_classify_regex_classifier",
      "label": "Regex Prompt Harm Classifier",
      "file_type": "code",
      "source_file": "src/lib/classify.ts",
