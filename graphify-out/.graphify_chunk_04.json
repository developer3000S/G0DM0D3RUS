      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Fast client-side regex/keyword matcher that categorizes prompts into cyber, fraud, self-harm, etc., with zero API cost. Collects telemetry without sending full prompt text, ensuring user privacy."
    },
    {
      "id": "lib_autotunefeedback_ema_learning",
      "label": "Exponential Moving Average Feedback Adaptation",
      "file_type": "rationale",
      "source_file": "src/lib/autotune-feedback.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "By applying Exponential Moving Average (EMA) to rating adjustments, the feedback loop can smoothly adapt to user preferences without reacting too aggressively to individual noise, ensuring stability over time."
    },
    {
      "id": "lib_autotune_pre_generation_tuning",
      "label": "Pre-Generation Parameter Tuning",
      "file_type": "rationale",
      "source_file": "src/lib/autotune.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Instead of the costly brute-force generation and post-hoc selection of AutoTemp, evaluating the prompt's context on the client-side allows choosing optimal temperature and sampling settings immediately, achieving similar intelligence with 1/N cost."
    },
    {
      "id": "lib_classify_privacy_preserving_telemetry",
      "label": "Privacy-Preserving Harm Telemetry",
      "file_type": "rationale",
      "source_file": "src/lib/classify.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Only harm domain labels and weights are sent to telemetry servers, never the user's prompt text itself. This maintains absolute user privacy while allowing researchers to collect aggregate stats on jailbreaks and exploit queries."
    },
