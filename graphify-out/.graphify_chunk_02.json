    {
      "id": "lib_ultraplinian_early_exit_racing",
      "label": "Early-Exit Model Racing",
      "file_type": "rationale",
      "source_file": "HF/api/lib/ultraplinian.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Cuts p95 latency dramatically without degrading quality by resolving as soon as minResults are in plus a grace window."
    },
    {
      "id": "lib_autotune_pre_generation_context_analysis",
      "label": "Pre-Generation Context Analysis",
      "file_type": "rationale",
      "source_file": "HF/src/lib/autotune.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Instead of brute-forcing multiple generations and judging outputs (like Elder Plinius's AutoTemp), AutoTune analyzes context BEFORE generation and applies optimal parameters in a single call. Same intelligence, 1/N the cost."
    },
    {
      "id": "lib_parseltongue_input_obfuscation",
      "label": "Parseltongue Input Obfuscation",
      "file_type": "rationale",
      "source_file": "HF/src/lib/parseltongue.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Detects trigger words likely to cause model refusals and applies obfuscation techniques (Leetspeak, Unicode homoglyphs, mixed case, zero-width joiners) to bypass content filters."
    },
    {
      "id": "lib_autotune_feedback_ema_learning",
      "label": "Feedback Loop Exponential Moving Average Learning",
      "file_type": "rationale",
      "source_file": "HF/src/lib/autotune-feedback.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Learns from user ratings to adjust AutoTune parameters over time using Exponential Moving Average per context type, blending adjustments capped at 50% weight so base profiles remain the foundation."
    },
    {
      "id": "routes_ultraplinian_liquid_response_streaming",
      "label": "Liquid Response Streaming Mode",
      "file_type": "rationale",
      "source_file": "HF/api/routes/ultraplinian.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Serves the first good response immediately, then auto-upgrades when a new model beats the current leader by a minimum delta. This ensures immediate responsiveness while guaranteeing high final quality."
    },
    {
      "id": "lib_metadata_zdr_privacy_first_analytics",
      "label": "ZDR Privacy-First Analytics",
      "file_type": "rationale",
      "source_file": "HF/api/lib/metadata.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Records everything about requests (durations, modes, errors, parameter deltas) except actual prompt/response content or PII. Keeps ring-buffer in memory to avoid persistent tracking."
    },
    {
      "id": "lib_dataset_open_dataset_collection",
      "label": "Open Dataset Collection",
      "file_type": "rationale",
      "source_file": "HF/api/lib/dataset.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Provides strictly opt-in, anonymized data collection for community research, stripping system prompts to prevent leaking custom prompts, exportable via GDPR-compliant APIs."
    }
